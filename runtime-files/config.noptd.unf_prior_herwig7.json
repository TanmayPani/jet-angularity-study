{
  "num_replicas": 20,
  "num_data_subsample": 500000,
  "batch_size": 5000,
  "train_size": 0.75,
  "num_iterations": 7,
  "num_epochs": 30,
  "dataseed": 0,
  "modelseed": 0,
  "feature_mode": "angularities_noptd",
  "input_transform": "z_norm",
  "redo_preprocessing": false,
  "redo_datasets": true,
  "redo_closure_datasets": false,
  "save_model_states": true,
  "early_stop_on_convergence": false,
  "step_odds_clip": {
    "clamp_min": 0.001,
    "clamp_max": 1000.0
  },
  "compile_forward": false,
  "compile_kwargs": {},
  "barlow_threshold": 1.0,
  "dataset_root": "./datasets/STAR_pp200GeV_production_2012",
  "device": "auto",
  "sys_var": "unf_prior_herwig7",
  "training": {
    "hidden_layers": [
      256,
      256,
      256
    ],
    "dropout_prob": 0.2,
    "early_stopping_patience": 10,
    "reweight_clamp": {
      "clamp_min": 0.001,
      "clamp_max": 1000.0
    },
    "cnn_channels": [
      32,
      64
    ],
    "predict_replica_chunk": 2,
    "optimizer": {
      "lr": 0.001,
      "eps": 1e-8,
      "weight_decay": 0.01,
      "decoupled_weight_decay": true
    }
  },
  "filename_stub_fmt": "nreplicas{}_sub{}_batch_size{}_niter{}_nepochs{}_trainsplit{}_dataseed{}_modelseed{}"
}
